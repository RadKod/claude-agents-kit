{
  "permissions": {
    "allow": [
      "Bash(flutter *)", "Bash(dart *)", "Bash(pub *)",
      "Bash(npx *)", "Bash(git *)",
      "Bash(cat *)", "Bash(ls *)", "Bash(find *)",
      "Bash(grep *)", "Bash(mkdir *)", "Bash(adb *)",
      "Bash(xcrun *)", "Bash(open *)"
    ],
    "deny": [
      "Bash(rm -rf /)", "Bash(rm -rf .)", "Bash(*--force*)",
      "Bash(*sudo*)", "Read(.env)", "Read(.env.*)"
    ]
  },
  "hooks": {
    "PostToolUse": [{
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [{"type": "command", "command": "filepath=$(cat | jq -r '.tool_input.file_path // .tool_input.path // empty'); if [ -n \"$filepath\" ] && echo \"$filepath\" | grep -qE '\\.dart$'; then dart format \"$filepath\" 2>/dev/null; fi; exit 0"}]
    }],
    "PreToolUse": [{
      "matcher": "Bash",
      "hooks": [{"type": "command", "command": "bash .claude/hooks/pre-bash-firewall.sh"}]
    }]
  }
}
