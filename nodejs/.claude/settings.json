{
  "permissions": {
    "allow": [
      "Bash(npm *)", "Bash(npx *)", "Bash(node *)",
      "Bash(npx drizzle-kit *)", "Bash(npx tsx *)",
      "Bash(npx vitest *)", "Bash(npx prettier *)", "Bash(npx eslint *)",
      "Bash(git *)", "Bash(cat *)", "Bash(ls *)", "Bash(find *)",
      "Bash(grep *)", "Bash(mkdir *)", "Bash(curl *)"
    ],
    "deny": [
      "Bash(rm -rf /)", "Bash(rm -rf .)", "Bash(*--force*)",
      "Bash(*sudo*)", "Read(.env)", "Read(.env.*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{"type": "command", "command": "filepath=$(cat | jq -r '.tool_input.file_path // .tool_input.path // empty'); if [ -n \"$filepath\" ] && echo \"$filepath\" | grep -qE '\\.(ts|tsx|js|json)$'; then npx prettier --write \"$filepath\" 2>/dev/null && npx eslint --fix \"$filepath\" 2>/dev/null; fi; exit 0"}]
      }
    ],
    "PreToolUse": [{
      "matcher": "Bash",
      "hooks": [{"type": "command", "command": "bash .claude/hooks/pre-bash-firewall.sh"}]
    }]
  }
}
